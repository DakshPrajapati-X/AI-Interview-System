# Environment Variables
# Copy this file to .env and fill in your values.
# Do NOT commit .env to version control.

# OpenRouter API key — used by the backend server
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenRouter API key — used by the React frontend (must start with REACT_APP_)
REACT_APP_OPENROUTER_API_KEY=your_openrouter_api_key_here

# AI model to use (defaults are provided in code if omitted)
OPENROUTER_MODEL=openai/gpt-4o-mini
REACT_APP_MODEL_NAME=openai/gpt-4o-mini

# Application origin for CORS and HTTP-Referer header
APP_ORIGIN=http://localhost:3000

# Backend server port
PORT=5000

# API URL for Frontend (Required for Vercel/Netlify pointing to Render)
REACT_APP_API_URL=https://ai-interview-system-n5dq.onrender.com
